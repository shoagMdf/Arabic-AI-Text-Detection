    {
      "title": "7. FIGURE 4 — Top-20 Words Human vs AI",
      "text": "%pyspark\n\ntop_n = 20\nh_top = human_counter.most_common(top_n)\na_top = ai_counter.most_common(top_n)\n\nh_words  = [shape_ar(w) for w, _ in h_top][::-1]\nh_counts = [c for _, c in h_top][::-1]\na_words  = [shape_ar(w) for w, _ in a_top][::-1]\na_counts = [c for _, c in a_top][::-1]\n\nfig, axes = plt.subplots(1, 2, figsize=(18, 9))\nbars_h = axes[0].barh(h_words, h_counts, color=HUMAN_COLOR, edgecolor=NAVY)\nfor bar, val in zip(bars_h, h_counts):\n    axes[0].text(val + max(h_counts)*0.01, bar.get_y() + bar.get_height()/2,\n                 f'{val:,}', va='center', fontweight='bold')\naxes[0].set_xlabel('Frequency', fontsize=12, fontweight='bold')\naxes[0].set_title(f'Top-{top_n} Words — Human', fontsize=14, fontweight='bold', color=HUMAN_COLOR)\n\nbars_a = axes[1].barh(a_words, a_counts, color=AI_COLOR, edgecolor=NAVY)\nfor bar, val in zip(bars_a, a_counts):\n    axes[1].text(val + max(a_counts)*0.01, bar.get_y() + bar.get_height()/2,\n                 f'{val:,}', va='center', fontweight='bold')\naxes[1].set_xlabel('Frequency', fontsize=12, fontweight='bold')\naxes[1].set_title(f'Top-{top_n} Words — AI', fontsize=14, fontweight='bold', color='#B57A0E')\n\nfig.suptitle('Top-20 Most Frequent Arabic Stems: Human vs AI',\n             fontsize=16, fontweight='bold', y=1.02)\nplt.tight_layout()\nout = f'{FIGURES_DIR}/04_top_words_human_vs_ai.png'\nfig.savefig(out, dpi=150, bbox_inches='tight', facecolor='white')\nplt.close(fig)\nprint(f'✅ Saved: {out}')",
