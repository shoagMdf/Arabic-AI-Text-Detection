    {
      "title": "5. FIGURE 2 — TTR (Type-Token Ratio) Human vs AI",
      "text": "%pyspark\n\ndef ttr_per_doc(text):\n    if not text: return 0.0\n    tokens = text.split()\n    return len(set(tokens)) / len(tokens) if tokens else 0.0\n\ndef count_unique(text): return len(set(text.split())) if text else 0\ndef count_total(text):  return len(text.split())      if text else 0\n\nttr_udf    = F.udf(ttr_per_doc, FloatType())\nunique_udf = F.udf(count_unique, IntegerType())\ntotal_udf  = F.udf(count_total,  IntegerType())\n\ndf_ttr = (df.withColumn('ttr',    ttr_udf('processed_text'))\n            .withColumn('unique', unique_udf('processed_text'))\n            .withColumn('total',  total_udf('processed_text')))\n\nstats = (df_ttr.groupBy('category_encode')\n               .agg(F.avg('ttr').alias('avg_ttr'),\n                    F.sum('unique').alias('total_unique'),\n                    F.sum('total').alias('total_tokens'))\n               .collect())\nstat_dict = {r['category_encode']: r for r in stats}\nh, a = stat_dict[1], stat_dict[0]\nh_corp = h['total_unique'] / h['total_tokens']\na_corp = a['total_unique'] / a['total_tokens']\n\nprint(f\"Human TTR (per-doc avg): {h['avg_ttr']:.4f}  |  Corpus-level: {h_corp:.4f}\")\nprint(f\"AI    TTR (per-doc avg): {a['avg_ttr']:.4f}  |  Corpus-level: {a_corp:.4f}\")\n\n# Collect for distribution plot\nttr_data = df_ttr.select('category_encode', 'ttr').toPandas()\n\nfig, axes = plt.subplots(1, 2, figsize=(15, 6))\n\n# (a) Bar comparison\nx = np.arange(2); width = 0.35\naxes[0].bar(x - width/2, [h['avg_ttr'], a['avg_ttr']], width,\n            label='Per-doc Avg', color=[HUMAN_COLOR, AI_COLOR], edgecolor=NAVY)\naxes[0].bar(x + width/2, [h_corp, a_corp], width,\n            label='Corpus-level', color=[HUMAN_COLOR, AI_COLOR], edgecolor=NAVY, hatch='///', alpha=0.6)\nfor i, (v1, v2) in enumerate(zip([h['avg_ttr'], a['avg_ttr']], [h_corp, a_corp])):\n    axes[0].text(i - width/2, v1 + 0.005, f'{v1:.4f}', ha='center', fontweight='bold')\n    axes[0].text(i + width/2, v2 + 0.005, f'{v2:.4f}', ha='center', fontweight='bold')\naxes[0].set_xticks(x); axes[0].set_xticklabels(['Human', 'AI'], fontsize=12)\naxes[0].set_ylabel('TTR', fontsize=12, fontweight='bold')\naxes[0].set_title('(a) TTR Comparison', fontsize=13, fontweight='bold')\naxes[0].legend()\n\n# (b) Distribution\naxes[1].hist(ttr_data[ttr_data.category_encode==1].ttr, bins=40,\n             color=HUMAN_COLOR, alpha=0.7, label='Human', edgecolor='white')\naxes[1].hist(ttr_data[ttr_data.category_encode==0].ttr, bins=40,\n             color=AI_COLOR, alpha=0.7, label='AI', edgecolor='white')\naxes[1].set_xlabel('Per-Doc TTR', fontsize=12, fontweight='bold')\naxes[1].set_ylabel('Frequency', fontsize=12, fontweight='bold')\naxes[1].set_title('(b) Per-Doc TTR Distribution', fontsize=13, fontweight='bold')\naxes[1].legend()\n\nfig.suptitle('Type-Token Ratio: Human vs AI', fontsize=15, fontweight='bold', y=1.02)\nplt.tight_layout()\nout = f'{FIGURES_DIR}/02_ttr_human_vs_ai.png'\nfig.savefig(out, dpi=150, bbox_inches='tight', facecolor='white')\nplt.close(fig)\nprint(f'✅ Saved: {out}')",
