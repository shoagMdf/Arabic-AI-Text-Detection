    {
      "title": "8. FIGURE 5 — Top-20 Bigrams (N-Grams) Human vs AI",
      "text": "%pyspark\n\ndef extract_bigrams(text):\n    if not text: return []\n    tokens = text.split()\n    return [f'{tokens[i]} {tokens[i+1]}' for i in range(len(tokens)-1)\n            if len(tokens[i]) > 1 and len(tokens[i+1]) > 1]\n\nprint('Collecting Human bigrams...')\nhuman_bg = Counter((df.filter(F.col('category_encode')==1)\n                      .select('processed_text').rdd\n                      .flatMap(lambda r: extract_bigrams(r[0])).collect()))\nprint(f'  {sum(human_bg.values()):,} bigrams')\n\nprint('Collecting AI bigrams...')\nai_bg = Counter((df.filter(F.col('category_encode')==0)\n                   .select('processed_text').rdd\n                   .flatMap(lambda r: extract_bigrams(r[0])).collect()))\nprint(f'  {sum(ai_bg.values()):,} bigrams')\n\ntop_n = 20\nh_top = human_bg.most_common(top_n)\na_top = ai_bg.most_common(top_n)\n\nh_bigs   = [shape_ar(bg) for bg, _ in h_top][::-1]\nh_counts = [c for _, c in h_top][::-1]\na_bigs   = [shape_ar(bg) for bg, _ in a_top][::-1]\na_counts = [c for _, c in a_top][::-1]\n\nfig, axes = plt.subplots(1, 2, figsize=(20, 10))\nbars_h = axes[0].barh(h_bigs, h_counts, color=HUMAN_COLOR, edgecolor=NAVY)\nfor bar, val in zip(bars_h, h_counts):\n    axes[0].text(val + max(h_counts)*0.01, bar.get_y() + bar.get_height()/2,\n                 f'{val:,}', va='center', fontweight='bold')\naxes[0].set_xlabel('Frequency', fontsize=12, fontweight='bold')\naxes[0].set_title(f'Top-{top_n} Bigrams — Human', fontsize=14, fontweight='bold', color=HUMAN_COLOR)\n\nbars_a = axes[1].barh(a_bigs, a_counts, color=AI_COLOR, edgecolor=NAVY)\nfor bar, val in zip(bars_a, a_counts):\n    axes[1].text(val + max(a_counts)*0.01, bar.get_y() + bar.get_height()/2,\n                 f'{val:,}', va='center', fontweight='bold')\naxes[1].set_xlabel('Frequency', fontsize=12, fontweight='bold')\naxes[1].set_title(f'Top-{top_n} Bigrams — AI', fontsize=14, fontweight='bold', color='#B57A0E')\n\nfig.suptitle('Top-20 Most Frequent Bigrams: Human vs AI',\n             fontsize=16, fontweight='bold', y=1.01)\nplt.tight_layout()\nout = f'{FIGURES_DIR}/05_bigrams_human_vs_ai.png'\nfig.savefig(out, dpi=150, bbox_inches='tight', facecolor='white')\nplt.close(fig)\nprint(f'✅ Saved: {out}')",
