    {
      "title": "9. FIGURE 6 — AI-Distinctive Bigrams (AI Fingerprints)",
      "text": "%pyspark\n\nn_human = human_count\nn_ai    = ai_count\n\ndistinctive = []\nfor bigram, ai_c in ai_bg.most_common(500):\n    h_c = human_bg.get(bigram, 0)\n    ai_norm = ai_c / n_ai\n    h_norm  = (h_c + 1) / (n_human + 1)\n    ratio   = ai_norm / h_norm if h_norm > 0 else 0\n    if ai_c >= 100:\n        distinctive.append((bigram, h_c, ai_c, ratio))\n\ndistinctive.sort(key=lambda x: x[3], reverse=True)\ntop = distinctive[:15]\n\nbigs   = [shape_ar(d[0]) for d in top][::-1]\nh_cnts = [d[1] for d in top][::-1]\na_cnts = [d[2] for d in top][::-1]\nratios = [d[3] for d in top][::-1]\n\nfig, ax = plt.subplots(figsize=(14, 9))\ny_pos = np.arange(len(bigs))\nwidth = 0.4\n\nax.barh(y_pos - width/2, h_cnts, width, label='Human', color=HUMAN_COLOR, edgecolor=NAVY)\nbars_a = ax.barh(y_pos + width/2, a_cnts, width, label='AI', color=AI_COLOR, edgecolor=NAVY)\n\nfor bar, val, ratio in zip(bars_a, a_cnts, ratios):\n    ax.text(val + max(a_cnts)*0.01, bar.get_y() + bar.get_height()/2,\n            f'{val:,} ({ratio:.1f}×)', va='center', fontweight='bold')\n\nax.set_yticks(y_pos); ax.set_yticklabels(bigs, fontsize=11)\nax.set_xlabel('Frequency (AI/Human Ratio)', fontsize=12, fontweight='bold')\nax.set_title('Top-15 AI-Distinctive Bigrams (Highest AI/Human Ratio)',\n             fontsize=14, fontweight='bold', pad=15)\nax.legend(loc='lower right', fontsize=12)\n\nfig.suptitle('AI Fingerprints: Bigrams Disproportionately Used by AI',\n             fontsize=16, fontweight='bold')\nplt.tight_layout()\nout = f'{FIGURES_DIR}/06_distinctive_bigrams.png'\nfig.savefig(out, dpi=150, bbox_inches='tight', facecolor='white')\nplt.close(fig)\nprint(f'✅ Saved: {out}')",
