    {
      "title": "6. FIGURE 3 — Word Clouds Human vs AI",
      "text": "%pyspark\n\nFONT_CANDIDATES = [\n    '/usr/share/fonts/google-droid-sans-fonts/DroidKufi-Regular.ttf',\n    '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf',\n    '/usr/share/fonts/dejavu/DejaVuSans.ttf',\n]\nfont_path = next((p for p in FONT_CANDIDATES if os.path.exists(p)), None)\n\nprint('Collecting Human tokens...')\nhuman_tokens = (df.filter(F.col('category_encode')==1)\n                  .select('processed_text').rdd\n                  .flatMap(lambda r: (r[0] or '').split()).collect())\nprint(f'  {len(human_tokens):,} tokens')\n\nprint('Collecting AI tokens...')\nai_tokens = (df.filter(F.col('category_encode')==0)\n               .select('processed_text').rdd\n               .flatMap(lambda r: (r[0] or '').split()).collect())\nprint(f'  {len(ai_tokens):,} tokens')\n\nhuman_counter = Counter(t for t in human_tokens if len(t) > 1)\nai_counter    = Counter(t for t in ai_tokens    if len(t) > 1)\n\nhuman_freq = {shape_ar(w): c for w, c in human_counter.most_common(200)}\nai_freq    = {shape_ar(w): c for w, c in ai_counter.most_common(200)}\n\nwc_h = WordCloud(width=900, height=500, background_color='white', max_words=100,\n                 font_path=font_path, colormap='Blues', collocations=False).generate_from_frequencies(human_freq)\nwc_a = WordCloud(width=900, height=500, background_color='white', max_words=100,\n                 font_path=font_path, colormap='YlOrBr', collocations=False).generate_from_frequencies(ai_freq)\n\nfig, axes = plt.subplots(1, 2, figsize=(18, 7))\naxes[0].imshow(wc_h, interpolation='bilinear'); axes[0].axis('off')\naxes[0].set_title(f'Human-Written ({len(human_counter):,} unique stems)',\n                  fontsize=14, fontweight='bold', color=HUMAN_COLOR, pad=15)\naxes[1].imshow(wc_a, interpolation='bilinear'); axes[1].axis('off')\naxes[1].set_title(f'AI-Generated ({len(ai_counter):,} unique stems)',\n                  fontsize=14, fontweight='bold', color='#B57A0E', pad=15)\nfig.suptitle('Word Cloud Comparison: Most Frequent Arabic Stems',\n             fontsize=16, fontweight='bold', y=1.02)\nplt.tight_layout()\nout = f'{FIGURES_DIR}/03_wordcloud_human_vs_ai.png'\nfig.savefig(out, dpi=150, bbox_inches='tight', facecolor='white')\nplt.close(fig)\nprint(f'✅ Saved: {out}')",
